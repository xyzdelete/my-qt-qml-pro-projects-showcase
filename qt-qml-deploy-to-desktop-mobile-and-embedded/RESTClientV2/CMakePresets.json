{
  "version": 11,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/build/${presetName}/package/${sourceDirName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_COLOR_DIAGNOSTICS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_CXX_STANDARD": "23",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPERIMENTAL_CXX_IMPORT_STD": "451f2fe2-a8a2-47c3-bc32-94786d8fc91b",
        "CMAKE_CXX_MODULE_STD": "ON",
        "CMAKE_CXX_SCAN_FOR_MODULES": "ON",
        "QT_QML_GENERATE_QMLLS_INI": "ON",
        "USE_VCPKG": "ON"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": "base",
      "binaryDir": "$env{SystemDrive}/build/${presetName}",
      "installDir": "$env{SystemDrive}/build/${presetName}/package/${sourceDirName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl",
        "VCPKG_INSTALLED_DIR": "$env{SystemDrive}/vcpkg_installed",
        "VCPKG_INSTALL_OPTIONS": "--x-buildtrees-root=$env{SystemDrive}/vcpkg_buildtrees"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "x64-windows-static",
      "inherits": "windows-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>",
        "VCPKG_STATIC_LIBS_LINKING": "ON"
      }
    },
    {
      "name": "x64-windows-static-md",
      "inherits": "windows-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL$<$<CONFIG:Debug>:Debug>",
        "VCPKG_STATIC_LIBS_LINKING": "ON"
      }
    },
    {
      "name": "x64-windows",
      "inherits": "windows-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL$<$<CONFIG:Debug>:Debug>",
        "VCPKG_STATIC_LIBS_LINKING": "OFF"
      }
    },
    {
      "name": "arm64-windows-static-md",
      "inherits": "windows-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-windows-static-md",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL$<$<CONFIG:Debug>:Debug>",
        "CMAKE_SYSTEM_NAME": "Windows",
        "CMAKE_SYSTEM_PROCESSOR": "ARM64",
        "VCPKG_STATIC_LIBS_LINKING": "ON"
      }
    },
    {
      "name": "arm64-windows",
      "inherits": "windows-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-windows",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL$<$<CONFIG:Debug>:Debug>",
        "CMAKE_SYSTEM_NAME": "Windows",
        "CMAKE_SYSTEM_PROCESSOR": "ARM64",
        "VCPKG_STATIC_LIBS_LINKING": "OFF"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "x64-linux",
      "inherits": "linux-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux",
        "VCPKG_STATIC_LIBS_LINKING": "ON"
      }
    },
    {
      "name": "x64-linux-dynamic",
      "inherits": "linux-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "VCPKG_STATIC_LIBS_LINKING": "OFF"
      }
    },
    {
      "name": "arm64-linux",
      "inherits": "linux-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-linux",
        "CMAKE_SYSTEM_NAME": "Linux",
        "CMAKE_SYSTEM_PROCESSOR": "aarch64",
        "CMAKE_C_COMPILER": "aarch64-linux-gnu-gcc",
        "CMAKE_CXX_COMPILER": "aarch64-linux-gnu-g++",
        "VCPKG_STATIC_LIBS_LINKING": "ON"
      }
    },
    {
      "name": "arm64-linux-dynamic",
      "inherits": "linux-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-linux-dynamic",
        "CMAKE_SYSTEM_NAME": "Linux",
        "CMAKE_SYSTEM_PROCESSOR": "aarch64",
        "CMAKE_C_COMPILER": "aarch64-linux-gnu-gcc",
        "CMAKE_CXX_COMPILER": "aarch64-linux-gnu-g++",
        "VCPKG_STATIC_LIBS_LINKING": "OFF"
      }
    },
    {
      "name": "osx-base",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_OSX_ARCHITECTURES": "arm64"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "arm64-osx",
      "inherits": "osx-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-osx",
        "VCPKG_STATIC_LIBS_LINKING": "ON"
      }
    },
    {
      "name": "arm64-osx-dynamic",
      "inherits": "osx-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-osx-dynamic",
        "VCPKG_STATIC_LIBS_LINKING": "OFF"
      }
    },
    {
      "name": "arm64-ios",
      "inherits": "osx-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-ios",
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_SYSROOT": "iphoneos",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "26.0",
        "VCPKG_STATIC_LIBS_LINKING": "ON"
      }
    },
    {
      "name": "android-base",
      "hidden": true,
      "inherits": "base",
      "environment": {
        "ANDROID_NDK_HOME": "$env{ANDROID_NDK}"
      },
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Android",
        "CMAKE_ANDROID_NDK": "$env{ANDROID_NDK}",
        "CMAKE_ANDROID_STL_TYPE": "c++_static",
        "CMAKE_ANDROID_API": "36"
      }
    },
    {
      "name": "arm64-android",
      "inherits": "android-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-android",
        "CMAKE_ANDROID_ARCH_ABI": "arm64-v8a",
        "VCPKG_STATIC_LIBS_LINKING": "OFF"
      }
    },
    {
      "name": "x64-android",
      "inherits": "android-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-android",
        "CMAKE_ANDROID_ARCH_ABI": "x86_64",
        "VCPKG_STATIC_LIBS_LINKING": "OFF"
      }
    }
  ],
